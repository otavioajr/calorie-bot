# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# WhatsApp (Meta Cloud API)
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WEBHOOK_BASE_URL=

# LLM
LLM_PROVIDER=openrouter
LLM_API_KEY=
LLM_MODEL_MEAL=openai/gpt-4o-mini
LLM_MODEL_CLASSIFY=meta-llama/llama-3.1-8b-instruct:free
LLM_MODEL_VISION=openai/gpt-4o

# Ollama (only if LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL_MEAL=llama3.1:8b
OLLAMA_MODEL_CLASSIFY=llama3.1:8b

# Fallback (optional)
LLM_FALLBACK_PROVIDER=

# Cron
CRON_SECRET=

# App URL (used for web panel links in bot messages)
NEXT_PUBLIC_APP_URL=https://caloriebot.app
